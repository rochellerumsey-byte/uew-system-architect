# GitHub-backed storage for blueprints.
# Create a personal access token with `repo` scope:
#   https://github.com/settings/tokens
# Then point it at the repo where blueprints will be persisted.
GITHUB_TOKEN=
GITHUB_OWNER=rochellerumsey-byte
GITHUB_REPO=uew-system-architect
GITHUB_BRANCH=main

# Public app metadata (safe to expose in the browser bundle).
NEXT_PUBLIC_APP_NAME=System Architect
